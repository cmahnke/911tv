{
  "name": "911tv",
  "private": true,
  "version": "2026.5.11",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "Christian Mahnke",
  "person": {
    "name": "Christian Mahnke",
    "email": "911tv@projektemacher.org",
    "url": "https://christianmahnke.de/"
  },
  "homepage": "https://911tv.projektemacher.org/",
  "description": "In 2007, the Internet Archive set up the September 11 Television Archive, a collection of TV broadcasts from 20 channels over 7 days, totalling about 3000 hours of material. Although mainly US channels, it also includes some international channels. This digital exhibit presents the material on a virtual television screen with a minimalist user interface, allowing visitors to experience the event of that time in an immersive way, mirroring the media consumption patterns of the era.",
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/cmahnke/911tv/issues"
  },
  "repository": {
    "url": "git+https://github.com/cmahnke/911tv.git"
  },
  "license": "CC-BY-NC-4.0",
  "keywords": [
    "911",
    "TV",
    "Internet Archive",
    "September 11 Television Archive"
  ],
  "scripts": {
    "postinstall": "run-script-os",
    "postinstall:darwin": "patch-package",
    "postinstall:default": "",
    "dev": "npx vite",
    "prod": "npm run clean && vite build && vite preview",
    "build": "npx vite build",
    "tsc": "npx tsc",
    "clean": "rimraf dist/* out/*",
    "lint": "npx eslint . -c eslint.config.mjs",
    "stylelint": "npx stylelint 'src/**/*.scss'",
    "preview": "npx vite preview",
    "format": "npx prettier . --check",
    "app:start": "electron-vite preview",
    "app:dev": "electron-vite dev",
    "app": "electron-vite build",
    "app:win": "npm run app && electron-builder --win",
    "app:mac": "npm run app && electron-builder --mac",
    "app:linux": "npm run app && electron-builder --linux",
    "app:all": "npm run app && electron-builder -mwl"
  },
