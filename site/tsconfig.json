{
  "compilerOptions": {
    "module": "esnext",
    "strictPropertyInitialization": false,
    "noImplicitAny": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "noEmit": false,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "strict": true,
    "declaration": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "target": "es2022",
    "rootDir": "./src",
    "outDir": "build/compiled",
    "typeRoots": ["./node_modules/@types", "./src/@types"],
    "lib": ["dom", "es2022"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts", "electron/**/*", "dist/**/*", "out/**/*", "build/**/*"]
}
